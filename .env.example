# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Same project URL for Vercel serverless (optional; api/_server/supabaseAdmin falls back to VITE_SUPABASE_URL)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (chaos score + roast on /api/confess)
ANTHROPIC_API_KEY=
# Optional override — default claude-sonnet-4-20250514
# ANTHROPIC_MODEL=

# Gmail SMTP (Phase 6 — thank-you emails on End Session)
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=

# Host
HOST_PASSWORD=

# App
VITE_SESSION_ID=
# Sign-off + From display name in attendee emails
PRESENTER_NAME=

# Local dev: `npm run dev` handles POST /api/join, /api/confess, /api/upvote in-process (loads .env.local). Use `npm run dev:vercel` for the full Vercel runtime.
